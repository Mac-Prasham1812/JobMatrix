<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_bg_screen">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Post a New Job"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/color_text_primary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="20dp"
            android:text="Fill in the job details carefully to attract the right candidates."
            android:textSize="13sp"
            android:textColor="@color/color_text_secondary" />

        <!-- Job Title -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:padding="9dp"
                android:background="@drawable/ic_jobs"
                app:tint="@color/color_icon_tint"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Job Title"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="@color/color_text_primary" />

                <EditText
                    android:id="@+id/etTitle"
                    android:layout_width="match_parent"
                    android:layout_height="46dp"
                    android:layout_marginTop="4dp"
                    android:background="@drawable/bg_pipeline_card"
                    android:hint="e.g. Android Developer"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:textSize="14sp"
                    android:textColor="@color/color_text_primary"
                    android:textColorHint="@color/color_text_secondary" />
            </LinearLayout>
        </LinearLayout>

        <!-- Company Name -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:padding="9dp"
                android:background="@drawable/ic_company"
                app:tint="@color/color_icon_tint" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Company Name"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="@color/color_text_primary" />

                <EditText
                    android:id="@+id/etCompany"
                    android:layout_width="match_parent"
                    android:layout_height="46dp"
                    android:layout_marginTop="4dp"
                    android:background="@drawable/bg_pipeline_card"
                    android:hint="e.g. CodeXen Solutions"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:textSize="14sp"
                    android:textColor="@color/color_text_primary"
                    android:textColorHint="@color/color_text_secondary" />
            </LinearLayout>
        </LinearLayout>

        <!-- Location -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:padding="9dp"
                android:background="@drawable/ic_pin"
                app:tint="@color/color_icon_tint" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Location (City, State)"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="@color/color_text_primary" />

                <EditText
                    android:id="@+id/etLocation"
                    android:layout_width="match_parent"
                    android:layout_height="46dp"
                    android:layout_marginTop="4dp"
                    android:background="@drawable/bg_pipeline_card"
                    android:hint="e.g. Rajkot, Gujarat"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:textSize="14sp"
                    android:textColor="@color/color_text_primary"
                    android:textColorHint="@color/color_text_secondary" />
            </LinearLayout>
        </LinearLayout>

        <!-- Category -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:padding="9dp"
                android:src="@android:drawable/ic_menu_sort_by_size"
                android:background="@drawable/ic_business"
                app:tint="@color/color_icon_tint" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Category"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="@color/color_text_primary" />

                <EditText
                    android:id="@+id/etCategory"
                    android:layout_width="match_parent"
                    android:layout_height="46dp"
                    android:layout_marginTop="4dp"
                    android:background="@drawable/bg_pipeline_card"
                    android:hint="e.g. Development / Designing / Marketing"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:textSize="14sp"
                    android:textColor="@color/color_text_primary"
                    android:textColorHint="@color/color_text_secondary" />
            </LinearLayout>
        </LinearLayout>

        <!-- Package -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:padding="9dp"
                android:background="@drawable/ic_package"
                app:tint="@color/color_icon_tint"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Package"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="@color/color_text_primary" />

                <EditText
                    android:id="@+id/etSalary"
                    android:layout_width="match_parent"
                    android:layout_height="46dp"
                    android:layout_marginTop="4dp"
                    android:background="@drawable/bg_pipeline_card"
                    android:hint="e.g. ₹3,00,000 – ₹6,00,000"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:singleLine="true"
                    android:textSize="14sp"
                    android:textColor="@color/color_text_primary"
                    android:textColorHint="@color/color_text_secondary" />
            </LinearLayout>
        </LinearLayout>

        <!-- Experience -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:padding="9dp"
                android:background="@drawable/ic_business"
                app:tint="@color/color_icon_tint"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Experience Required"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="@color/color_text_primary" />

                <EditText
                    android:id="@+id/etExperience"
                    android:layout_width="match_parent"
                    android:layout_height="46dp"
                    android:layout_marginTop="4dp"
                    android:background="@drawable/bg_pipeline_card"
                    android:hint="e.g. 1 – 3 Years"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:textSize="14sp"
                    android:textColor="@color/color_text_primary"
                    android:textColorHint="@color/color_text_secondary" />
            </LinearLayout>
        </LinearLayout>

        <!-- Skills -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:padding="9dp"
                android:background="@drawable/ic_check"
                app:tint="@color/color_icon_tint"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Skills (comma separated)"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="@color/color_text_primary" />

                <EditText
                    android:id="@+id/etSkills"
                    android:layout_width="match_parent"
                    android:layout_height="46dp"
                    android:layout_marginTop="4dp"
                    android:background="@drawable/bg_pipeline_card"
                    android:hint="e.g. Kotlin, Firebase, MVVM"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:textSize="14sp"
                    android:textColor="@color/color_text_primary"
                    android:textColorHint="@color/color_text_secondary" />
            </LinearLayout>
        </LinearLayout>

        <!-- Company Overview -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="20dp">

            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:padding="9dp"
                android:background="@drawable/ic_company"
                app:tint="@android:color/white" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Company Overview"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="@color/color_text_primary" />

                <EditText
                    android:id="@+id/etCompanyOverview"
                    android:layout_width="match_parent"
                    android:layout_height="110dp"
                    android:layout_marginTop="4dp"
                    android:background="@drawable/bg_pipeline_card"
                    android:gravity="top|start"
                    android:hint="Write about your company, culture, values and what makes it great to work with you..."
                    android:inputType="textMultiLine"
                    android:padding="12dp"
                    android:textSize="14sp"
                    android:textColor="@color/color_text_primary"
                    android:textColorHint="@color/color_text_secondary" />
            </LinearLayout>
        </LinearLayout>

        <Button
            android:id="@+id/btnPostJob"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_button_rect"
            android:text="POST JOB"
            android:textAllCaps="true"
            android:textStyle="bold"
            android:textColor="@android:color/white" />

    </LinearLayout>
</ScrollView>