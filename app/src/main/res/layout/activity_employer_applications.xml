<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/color_bg_screen">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/ivBack"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_back"
            app:tint="@color/color_text_primary"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:text="Applications"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/color_text_primary"/>

        <ImageView
            android:id="@+id/ivFilter"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_filter"
            app:tint="@color/color_text_primary"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingBottom="12dp"
        android:weightSum="3">

        <TextView
            android:id="@+id/tabAll"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:gravity="center"
            android:paddingVertical="8dp"
            android:text="All"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:background="@drawable/bg_chip_active"/>

        <TextView
            android:id="@+id/tabShortlisted"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:gravity="center"
            android:paddingVertical="8dp"
            android:text="Shortlisted"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="@color/color_text_secondary"
            android:background="@drawable/bg_chip"/>

        <TextView
            android:id="@+id/tabRejected"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:paddingVertical="8dp"
            android:text="Rejected"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="@color/color_text_secondary"
            android:background="@drawable/bg_chip"/>
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvApplications"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="16dp"
        android:clipToPadding="false"
        android:overScrollMode="never"/>

</LinearLayout>