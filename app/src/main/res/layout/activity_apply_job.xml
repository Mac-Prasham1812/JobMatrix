<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="#FFFFFF">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Upload Resume"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#000000"/>

    <!-- Instructions -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Steps to upload your resume:"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#000000"
        android:layout_marginTop="12dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="1. Upload your resume file to Google Drive."
        android:textSize="17sp"
        android:textColor="#555555"
        android:layout_marginTop="6dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="2. Right-click the file and select 'Get link'."
        android:textSize="17sp"
        android:textColor="#555555"
        android:layout_marginTop="4dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="3. Change access to 'Anyone with the link can view'."
        android:textSize="17sp"
        android:textColor="#D32F2F"
        android:textStyle="bold"
        android:layout_marginTop="4dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="4. Copy the link and paste it below."
        android:textSize="17sp"
        android:textColor="#555555"
        android:layout_marginTop="4dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Paste Google Drive Resume Link"
        android:textSize="17sp"
        android:textColor="#666666"
        android:layout_marginTop="18dp"/>

    <EditText
        android:id="@+id/etResumeLink"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="https://drive.google.com/..."
        android:background="@drawable/bg_input"
        android:padding="12dp"
        android:layout_marginTop="8dp"
        android:textSize="17sp"
        android:textColorHint="@color/gray"
        android:textColor="@color/black"/>

    <Button
        android:id="@+id/btnSubmitApplication"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Submit Application"
        android:textSize="17sp"
        android:layout_marginTop="20dp"
        android:backgroundTint="#1565C0"
        android:textColor="#FFFFFF"/>

</LinearLayout>
