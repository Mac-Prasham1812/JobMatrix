<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_bg_screen"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="18dp">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_back"
                app:tint="@color/color_text_primary"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless" />

            <TextView
                android:id="@+id/tvHeaderTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="14dp"
                android:text="Apply for Job"
                android:textSize="18sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end"
                android:textColor="@color/color_text_primary" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Upload your resume"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/color_text_primary"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Supported formats: PDF • up to 5 MB"
                android:textSize="12sp"
                android:textColor="@color/color_text_hint"
                android:layout_marginBottom="14dp"/>

            <androidx.cardview.widget.CardView
                android:id="@+id/cardResume"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@android:color/transparent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        android:id="@+id/layoutPickFile"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center_horizontal"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="@drawable/bg_dashed_picker"
                        android:padding="36dp">

                        <ImageView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:src="@drawable/ic_upload_file"
                            app:tint="@color/color_accent"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Drag &amp; drop your resume here"
                            android:textSize="14sp"
                            android:textColor="@color/color_text_secondary"
                            android:layout_marginTop="14dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="or"
                            android:textSize="12sp"
                            android:textColor="@color/color_text_hint"
                            android:layout_marginTop="4dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Choose file"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="@color/color_accent"
                            android:background="@drawable/bg_pipeline_card"
                            android:paddingHorizontal="24dp"
                            android:paddingVertical="10dp"
                            android:layout_marginTop="12dp"/>

                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/layoutFileChip"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="@drawable/bg_pipeline_card"
                        android:padding="16dp"
                        android:visibility="gone">

                        <ImageView
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:src="@drawable/ic_pdf"
                            android:background="@drawable/bg_circle_red"
                            android:padding="8dp"/>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="12dp">

                            <TextView
                                android:id="@+id/tvFileName"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="resume.pdf"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:textColor="@color/color_text_primary"
                                android:maxLines="1"
                                android:ellipsize="middle"/>

                            <TextView
                                android:id="@+id/tvFileSize"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0 KB"
                                android:textSize="12sp"
                                android:textColor="@color/color_text_hint"
                                android:layout_marginTop="3dp"/>
                        </LinearLayout>

                        <ImageView
                            android:id="@+id/btnRemoveFile"
                            android:layout_width="30dp"
                            android:layout_height="30dp"
                            android:src="@drawable/ic_close"
                            app:tint="@color/color_text_hint"
                            android:clickable="true"
                            android:focusable="true"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:padding="6dp"/>

                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/layoutProgress"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="@drawable/bg_pipeline_card"
                        android:padding="14dp"
                        android:layout_marginTop="14dp"
                        android:visibility="gone">

                        <ProgressBar
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:indeterminateTint="@color/color_accent"/>

                        <TextView
                            android:id="@+id/tvUploadStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Uploading resume..."
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="@color/color_accent"
                            android:layout_marginStart="10dp"/>

                    </LinearLayout>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/layoutAlreadyApplied"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/color_surface"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center_horizontal"
                    android:padding="36dp">

                    <ImageView
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:src="@drawable/ic_check"
                        android:background="@drawable/bg_circle_green"
                        android:padding="14dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Already Applied"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/color_text_primary"
                        android:layout_marginTop="16dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="You have already applied to this job."
                        android:textSize="14sp"
                        android:textColor="@color/color_text_hint"
                        android:gravity="center"
                        android:layout_marginTop="6dp"/>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <LinearLayout
                android:id="@+id/layoutInfoNote"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/bg_pipeline_card"
                android:padding="14dp"
                android:layout_marginTop="16dp"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_info"
                    app:tint="@color/color_accent"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="10dp"
                    android:text="Your data is secure and only shared with relevant recruiters."
                    android:textSize="12sp"
                    android:textColor="@color/color_text_secondary"/>

            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSubmitApplication"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="SUBMIT APPLICATION"
                android:textAllCaps="true"
                android:textStyle="bold"
                android:textSize="15sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="@color/color_accent"
                app:cornerRadius="16dp"
                app:elevation="4dp"
                android:layout_marginTop="24dp"/>

            <TextView
                android:id="@+id/tvSubmitHint"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:text="Select a PDF resume to continue"
                android:textSize="13sp"
                android:textColor="@color/color_text_hint"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="8dp"/>

        </LinearLayout>

    </LinearLayout>

</ScrollView>