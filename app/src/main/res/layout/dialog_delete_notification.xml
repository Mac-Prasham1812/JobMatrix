<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="300dp"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_dialog_premium"
    android:orientation="vertical"
    android:padding="20dp"
    android:elevation="10dp">

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Delete Notification"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#0A2540" />

    <TextView
        android:id="@+id/tvMessage"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Are you sure you want to delete this notification?"
        android:textSize="14sp"
        android:textColor="#374151"
        android:layout_marginTop="8dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end"
        android:layout_marginTop="20dp">

        <TextView
            android:id="@+id/btnCancel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cancel"
            android:textColor="#2563EB"
            android:textStyle="bold"
            android:padding="10dp"
            android:background="@drawable/ripple_text"
            android:clickable="true"
            android:focusable="true"/>

        <TextView
            android:id="@+id/btnDelete"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Delete"
            android:textColor="#DC2626"
            android:textStyle="bold"
            android:padding="10dp"
            android:layout_marginStart="20dp"
            android:background="@drawable/ripple_text"
            android:clickable="true"
            android:focusable="true"/>
    </LinearLayout>

</LinearLayout>
