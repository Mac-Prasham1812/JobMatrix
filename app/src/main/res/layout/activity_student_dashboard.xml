<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/color_bg_screen"
    android:fitsSystemWindows="true">

    <!-- TOP HEADER -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="20dp"
        android:paddingEnd="12dp"
        android:paddingTop="22dp"
        android:paddingBottom="22dp"
        android:gravity="center_vertical">
<!--        android:background="@color/color_surface"-->

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvGreeting"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Good Morning"
                android:textSize="14sp"
                android:textColor="@color/color_text_secondary"/>

            <TextView
                android:id="@+id/tvUserName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="User"
                android:textSize="21sp"
                android:textStyle="bold"
                android:textColor="@color/color_text_primary"
                android:layout_marginTop="2dp"/>
        </LinearLayout>

        <ImageView
            android:id="@+id/ivSettings"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:padding="10dp"
            android:src="@drawable/ic_settings"
            app:tint="@color/color_text_secondary"
            android:background="@drawable/ripple_circle"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="Settings"/>
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Your application pipeline"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="@color/color_text_primary"
        android:paddingStart="16dp"
        android:paddingTop="16dp"/>

    <!-- APPLICATION PIPELINE -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:weightSum="3">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="@drawable/bg_pipeline_card"
            android:padding="12dp"
            android:layout_marginEnd="6dp"
            android:gravity="center">

            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:padding="7dp"
                android:src="@drawable/ic_document"
                android:background="@drawable/bg_circle_blue"
                android:layout_marginBottom="6dp"/>

            <TextView
                android:id="@+id/tvAppliedCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@color/color_accent"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Applied"
                android:textSize="12sp"
                android:textColor="@color/color_text_secondary"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="@drawable/bg_pipeline_card"
            android:padding="12dp"
            android:layout_marginEnd="6dp"
            android:gravity="center">

            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:padding="7dp"
                android:src="@drawable/ic_eye"
                android:background="@drawable/bg_circle_orange"
                android:layout_marginBottom="6dp"/>

            <TextView
                android:id="@+id/tvInReviewCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#F59E0B"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="In Review"
                android:textSize="12sp"
                android:textColor="@color/color_text_secondary"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="@drawable/bg_pipeline_card"
            android:padding="12dp"
            android:gravity="center">

            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:padding="7dp"
                android:src="@drawable/ic_check"
                android:background="@drawable/bg_circle_green"
                android:layout_marginBottom="6dp"/>

            <TextView
                android:id="@+id/tvShortlistedCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#16A34A"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Shortlisted"
                android:textSize="12sp"
                android:textColor="@color/color_text_secondary"/>
        </LinearLayout>

    </LinearLayout>

