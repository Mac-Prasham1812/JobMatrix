<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/color_surface"
    android:padding="20dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Filter Jobs"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="@color/color_text_primary"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Location"
        android:textSize="13sp"
        android:textColor="@color/color_text_secondary"
        android:layout_marginBottom="6dp"/>

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        style="@style/InputLayoutStyle"
        android:layout_marginBottom="16dp">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etFilterLocation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="e.g. Rajkot"
            android:textColor="@color/color_text_primary"/>
    </com.google.android.material.textfield.TextInputLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Experience"
        android:textSize="13sp"
        android:textColor="@color/color_text_secondary"
        android:layout_marginBottom="6dp"/>

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:layout_marginBottom="16dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                style="@style/ChipActive"
                android:id="@+id/chipExpAny"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Any"/>

            <TextView
                style="@style/Chip"
                android:id="@+id/chipExpFresher"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Fresher"/>

            <TextView
                style="@style/Chip"
                android:id="@+id/chipExp1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1 Year"/>

            <TextView
                style="@style/Chip"
                android:id="@+id/chipExp2Plus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="2+ Years"/>
        </LinearLayout>
    </HorizontalScrollView>

    <TextView
        android:id="@+id/tvSalaryRangeLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Salary Range: 0 - 15 LPA"
        android:textSize="13sp"
        android:textColor="@color/color_text_secondary"
        android:layout_marginBottom="6dp"/>

    <com.google.android.material.slider.RangeSlider
        android:id="@+id/salarySlider"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:valueFrom="0"
        android:valueTo="15"
        android:stepSize="1"
        app:values="@array/default_salary_range"
        android:layout_marginBottom="20dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnResetFilter"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="Reset"
            android:textColor="@color/color_accent"
            app:strokeColor="@color/color_accent"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnApplyFilter"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="Apply"
            android:textColor="#FFFFFF"
            app:backgroundTint="@null"
            android:background="@drawable/bg_button"/>
    </LinearLayout>

</LinearLayout>